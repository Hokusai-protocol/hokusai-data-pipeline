{
  "$defs": {
    "DeltaOneContributorAllocation": {
      "additionalProperties": false,
      "description": "Contributor allocation metadata embedded in DeltaOne acceptance events.",
      "properties": {
        "wallet_address": {
          "description": "EIP-55 checksummed or lowercase 0x-prefixed Ethereum address",
          "title": "Wallet Address",
          "type": "string"
        },
        "weight_bps": {
          "description": "Allocation weight in basis points",
          "maximum": 10000,
          "minimum": 0,
          "title": "Weight Bps",
          "type": "integer"
        },
        "submissionId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Submissionid"
        },
        "contributionBatchId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contributionbatchid"
        },
        "contributorId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contributorid"
        }
      },
      "required": [
        "wallet_address",
        "weight_bps"
      ],
      "title": "DeltaOneContributorAllocation",
      "type": "object"
    },
    "DeltaOneGuardrailBreach": {
      "additionalProperties": false,
      "description": "A single guardrail violation in the acceptance event.",
      "properties": {
        "metric_name": {
          "minLength": 1,
          "title": "Metric Name",
          "type": "string"
        },
        "observed_bps": {
          "maximum": 10000,
          "minimum": 0,
          "title": "Observed Bps",
          "type": "integer"
        },
        "threshold_bps": {
          "maximum": 10000,
          "minimum": 0,
          "title": "Threshold Bps",
          "type": "integer"
        },
        "observed": {
          "title": "Observed",
          "type": "number"
        },
        "threshold": {
          "title": "Threshold",
          "type": "number"
        },
        "direction": {
          "pattern": "^(higher_is_better|lower_is_better)$",
          "title": "Direction",
          "type": "string"
        },
        "policy": {
          "minLength": 1,
          "title": "Policy",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "metric_name",
        "observed_bps",
        "threshold_bps",
        "observed",
        "threshold",
        "direction",
        "policy",
        "reason"
      ],
      "title": "DeltaOneGuardrailBreach",
      "type": "object"
    },
    "DeltaOneGuardrailSummary": {
      "additionalProperties": false,
      "description": "Aggregated guardrail evaluation result embedded in the acceptance event.",
      "properties": {
        "total_guardrails": {
          "minimum": 0,
          "title": "Total Guardrails",
          "type": "integer"
        },
        "guardrails_passed": {
          "minimum": 0,
          "title": "Guardrails Passed",
          "type": "integer"
        },
        "breaches": {
          "items": {
            "$ref": "#/$defs/DeltaOneGuardrailBreach"
          },
          "title": "Breaches",
          "type": "array"
        }
      },
      "required": [
        "total_guardrails",
        "guardrails_passed"
      ],
      "title": "DeltaOneGuardrailSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Versioned acceptance event emitted before DeltaOne mint for on-chain DeltaVerifier.\n\nAll numeric scores are in basis points (0-10000).  Cost fields are in USDC\nmicro-units (6 decimals).  All SHA-256 hashes are lowercase, 0x-prefixed.",
  "properties": {
    "event_version": {
      "const": "deltaone.acceptance/v1",
      "default": "deltaone.acceptance/v1",
      "title": "Event Version"
    },
    "model_id": {
      "minLength": 1,
      "title": "Model Id",
      "type": "string"
    },
    "model_id_uint": {
      "description": "uint256 as decimal string for on-chain consumption",
      "title": "Model Id Uint",
      "type": "string"
    },
    "eval_id": {
      "minLength": 1,
      "title": "Eval Id",
      "type": "string"
    },
    "mlflow_run_id": {
      "minLength": 1,
      "title": "Mlflow Run Id",
      "type": "string"
    },
    "benchmark_spec_id": {
      "minLength": 1,
      "title": "Benchmark Spec Id",
      "type": "string"
    },
    "primary_metric_name": {
      "minLength": 1,
      "title": "Primary Metric Name",
      "type": "string"
    },
    "primary_metric_mlflow_name": {
      "minLength": 1,
      "title": "Primary Metric Mlflow Name",
      "type": "string"
    },
    "metric_family": {
      "minLength": 1,
      "title": "Metric Family",
      "type": "string"
    },
    "baseline_score_bps": {
      "maximum": 10000,
      "minimum": 0,
      "title": "Baseline Score Bps",
      "type": "integer"
    },
    "candidate_score_bps": {
      "maximum": 10000,
      "minimum": 0,
      "title": "Candidate Score Bps",
      "type": "integer"
    },
    "delta_bps": {
      "maximum": 10000,
      "minimum": 0,
      "title": "Delta Bps",
      "type": "integer"
    },
    "delta_threshold_bps": {
      "maximum": 10000,
      "minimum": 0,
      "title": "Delta Threshold Bps",
      "type": "integer"
    },
    "attestation_hash": {
      "description": "SHA-256 of canonical HEM payload, 0x-prefixed",
      "title": "Attestation Hash",
      "type": "string"
    },
    "idempotency_key": {
      "description": "SHA-256 of model_id_uint:attestation_hash, 0x-prefixed",
      "title": "Idempotency Key",
      "type": "string"
    },
    "guardrail_summary": {
      "$ref": "#/$defs/DeltaOneGuardrailSummary"
    },
    "max_cost_usd_micro": {
      "minimum": 0,
      "title": "Max Cost Usd Micro",
      "type": "integer"
    },
    "actual_cost_usd_micro": {
      "minimum": 0,
      "title": "Actual Cost Usd Micro",
      "type": "integer"
    },
    "contributors": {
      "items": {
        "$ref": "#/$defs/DeltaOneContributorAllocation"
      },
      "title": "Contributors",
      "type": "array"
    }
  },
  "required": [
    "model_id",
    "model_id_uint",
    "eval_id",
    "mlflow_run_id",
    "benchmark_spec_id",
    "primary_metric_name",
    "primary_metric_mlflow_name",
    "metric_family",
    "baseline_score_bps",
    "candidate_score_bps",
    "delta_bps",
    "delta_threshold_bps",
    "attestation_hash",
    "idempotency_key",
    "guardrail_summary",
    "max_cost_usd_micro",
    "actual_cost_usd_micro"
  ],
  "title": "DeltaOneAcceptanceEvent",
  "type": "object"
}
