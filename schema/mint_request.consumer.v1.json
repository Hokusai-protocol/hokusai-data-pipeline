{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MintRequestConsumerCanonical",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "schema_version",
    "message_id",
    "timestamp",
    "model_id",
    "model_id_uint",
    "eval_id",
    "benchmark_spec_id",
    "dataset_hash",
    "attestation_hash",
    "idempotency_key",
    "baseline_commitment",
    "candidate_commitment",
    "attester_signatures",
    "totalSamples",
    "evaluation",
    "contributors"
  ],
  "properties": {
    "message_type": {
      "const": "mint_request",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "type": "string"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "model_id_uint": {
      "type": "string",
      "pattern": "^[1-9]\\d*$"
    },
    "eval_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_spec_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_hash": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "attestation_hash": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "baseline_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "candidate_commitment": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "attester_signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]{130}$"
      }
    },
    "totalSamples": {
      "type": "integer",
      "minimum": 1
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_name",
        "metric_family",
        "baseline_score_bps",
        "new_score_bps",
        "max_cost_usd_micro",
        "actual_cost_usd_micro"
      ],
      "properties": {
        "metric_name": {
          "type": "string",
          "minLength": 1
        },
        "metric_family": {
          "type": "string",
          "minLength": 1
        },
        "baseline_score_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "new_score_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "max_cost_usd_micro": {
          "type": "integer",
          "minimum": 0
        },
        "actual_cost_usd_micro": {
          "type": "integer",
          "minimum": 0
        },
        "sample_size_baseline": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "sample_size_candidate": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "ci_low_bps": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 10000
        },
        "ci_high_bps": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 10000
        },
        "p_value": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "effect_size_bps": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 10000
        },
        "statistical_method": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "statistical_reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1024
        }
      }
    },
    "contributors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "wallet_address",
          "weight_bps"
        ],
        "properties": {
          "wallet_address": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "weight_bps": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000
          },
          "submissionId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "contributionBatchId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "contributorId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        }
      }
    },
    "_retryCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
