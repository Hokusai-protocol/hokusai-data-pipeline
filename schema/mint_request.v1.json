{
  "$defs": {
    "MintRequestContributor": {
      "additionalProperties": false,
      "description": "A single contributor's wallet address and allocation weight for a MintRequest.",
      "properties": {
        "wallet_address": {
          "description": "EIP-55 checksummed or lowercase 0x-prefixed Ethereum address",
          "title": "Wallet Address",
          "type": "string"
        },
        "weight_bps": {
          "description": "Allocation weight in basis points",
          "maximum": 10000,
          "minimum": 1,
          "title": "Weight Bps",
          "type": "integer"
        },
        "submissionId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Submissionid"
        },
        "contributionBatchId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contributionbatchid"
        },
        "contributorId": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contributorid"
        },
        "recipientKind": {
          "default": "wallet",
          "description": "Mint-time reward routing decision for this contributor",
          "enum": [
            "wallet",
            "escrow"
          ],
          "title": "Recipientkind",
          "type": "string"
        }
      },
      "required": [
        "wallet_address",
        "weight_bps"
      ],
      "title": "MintRequestContributor",
      "type": "object"
    },
    "MintRequestEvaluation": {
      "additionalProperties": false,
      "description": "Evaluation scores and metadata embedded in a MintRequest.",
      "properties": {
        "metric_name": {
          "minLength": 1,
          "title": "Metric Name",
          "type": "string"
        },
        "metric_family": {
          "minLength": 1,
          "title": "Metric Family",
          "type": "string"
        },
        "baseline_score_bps": {
          "maximum": 10000,
          "minimum": 0,
          "title": "Baseline Score Bps",
          "type": "integer"
        },
        "new_score_bps": {
          "maximum": 10000,
          "minimum": 0,
          "title": "New Score Bps",
          "type": "integer"
        },
        "max_cost_usd_micro": {
          "minimum": 0,
          "title": "Max Cost Usd Micro",
          "type": "integer"
        },
        "actual_cost_usd_micro": {
          "minimum": 0,
          "title": "Actual Cost Usd Micro",
          "type": "integer"
        },
        "sample_size_baseline": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample Size Baseline"
        },
        "sample_size_candidate": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample Size Candidate"
        },
        "ci_low_bps": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Low Bps"
        },
        "ci_high_bps": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci High Bps"
        },
        "p_value": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "P Value"
        },
        "effect_size_bps": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effect Size Bps"
        },
        "statistical_method": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Statistical Method"
        },
        "statistical_reason": {
          "anyOf": [
            {
              "maxLength": 1024,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Statistical Reason"
        }
      },
      "required": [
        "metric_name",
        "metric_family",
        "baseline_score_bps",
        "new_score_bps",
        "max_cost_usd_micro",
        "actual_cost_usd_micro"
      ],
      "title": "MintRequestEvaluation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "MintRequest message published to hokusai:mint_requests on DeltaOne acceptance.\n\nAll score and delta fields are in basis points (0-10000).\nCost fields are in USDC micro-units (6 decimals).\nAll SHA-256 hashes are lowercase 0x-prefixed.",
  "properties": {
    "message_type": {
      "const": "mint_request",
      "default": "mint_request",
      "title": "Message Type"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version"
    },
    "message_id": {
      "description": "UUID or unique message identifier",
      "minLength": 1,
      "title": "Message Id",
      "type": "string"
    },
    "timestamp": {
      "description": "ISO-8601 UTC timestamp",
      "minLength": 1,
      "title": "Timestamp",
      "type": "string"
    },
    "model_id": {
      "minLength": 1,
      "title": "Model Id",
      "type": "string"
    },
    "model_id_uint": {
      "description": "uint256 as decimal string",
      "pattern": "^[1-9]\\d*$",
      "title": "Model Id Uint",
      "type": "string"
    },
    "eval_id": {
      "minLength": 1,
      "title": "Eval Id",
      "type": "string"
    },
    "benchmark_spec_id": {
      "description": "Stable benchmark spec identifier",
      "minLength": 1,
      "title": "Benchmark Spec Id",
      "type": "string"
    },
    "dataset_hash": {
      "description": "Dataset anchor, 0x-prefixed 64-hex SHA-256",
      "pattern": "^0x[0-9a-f]{64}$",
      "title": "Dataset Hash",
      "type": "string"
    },
    "attestation_hash": {
      "description": "SHA-256 of HEM payload, 0x-prefixed 64-hex",
      "pattern": "^0x[0-9a-f]{64}$",
      "title": "Attestation Hash",
      "type": "string"
    },
    "idempotency_key": {
      "description": "sha256(model_id_uint:attestation_hash), 0x-prefixed",
      "pattern": "^0x[0-9a-f]{64}$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "baseline_commitment": {
      "description": "Canonical on-chain lineage head for the model, 0x-prefixed 64-hex (sha256-merkle-v1)",
      "pattern": "^0x[0-9a-f]{64}$",
      "title": "Baseline Commitment",
      "type": "string"
    },
    "candidate_commitment": {
      "description": "SHA-256 Merkle root of candidate model weights, 0x-prefixed 64-hex (sha256-merkle-v1)",
      "pattern": "^0x[0-9a-f]{64}$",
      "title": "Candidate Commitment",
      "type": "string"
    },
    "attester_signatures": {
      "description": "Attester ECDSA signatures over the canonical MintRequest typed data, ordered by ascending recovered signer address",
      "items": {
        "pattern": "^0x[0-9a-fA-F]{130}$",
        "type": "string"
      },
      "maxItems": 8,
      "minItems": 0,
      "title": "Attester Signatures",
      "type": "array"
    },
    "totalSamples": {
      "description": "Total sample count submitted to DeltaVerifier, derived from accepted candidate samples",
      "minimum": 1,
      "title": "Totalsamples",
      "type": "integer"
    },
    "deadline": {
      "description": "HOK-2170: unix timestamp past which the attester signature is no longer submittable (DeltaVerifier reverts SignatureExpired). Set to now + 5 days at attest-build time; bound into the EIP-712 digest.",
      "minimum": 1,
      "title": "Deadline",
      "type": "integer"
    },
    "evaluation": {
      "$ref": "#/$defs/MintRequestEvaluation"
    },
    "contributors": {
      "items": {
        "$ref": "#/$defs/MintRequestContributor"
      },
      "minItems": 1,
      "title": "Contributors",
      "type": "array"
    }
  },
  "required": [
    "message_id",
    "timestamp",
    "model_id",
    "model_id_uint",
    "eval_id",
    "benchmark_spec_id",
    "dataset_hash",
    "attestation_hash",
    "idempotency_key",
    "baseline_commitment",
    "candidate_commitment",
    "attester_signatures",
    "totalSamples",
    "deadline",
    "evaluation",
    "contributors"
  ],
  "title": "MintRequest",
  "type": "object"
}
